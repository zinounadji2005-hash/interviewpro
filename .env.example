# Server Configuration
PORT=5000
NODE_ENV=development
BASE_URL=http://localhost:5000

# Database - Supabase PostgreSQL Connection String
# Get this from your Supabase project settings > Database > Connection string (URI)
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres?sslmode=require

# Session Secret - Generate a random string for production
SESSION_SECRET=your-super-secret-session-key-change-in-production

# Supabase Configuration
# Get these from your Supabase project settings > API
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Google Gemini API Key
# Get this from https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key

# Groq API Key (for Speech-to-Text)
# Get this from https://console.groq.com/keys
GROQ_API_KEY=your-groq-api-key

# OpenAI API Key (for Text-to-Speech)
# Note: Groq doesn't support TTS yet, so we use OpenAI for TTS
# Get this from https://platform.openai.com/api-keys
OPENAI_API_KEY=your-openai-api-key

# Frontend Environment Variables (for Vite)
# These are used in client/src/lib/supabase.ts
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
